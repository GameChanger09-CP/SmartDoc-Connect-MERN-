app.use('/api/users', userRoutes);

// 🛑 CRITICAL FIX: Handle missing API routes before serving the frontend
// Using app.use catches anything starting with /api safely without path-to-regexp crashing.
app.use('/api', (req, res) => {
    res.status(404).json({ error: 'API endpoint not found' });
});

// --- SERVE FRONTEND ---
const frontendDistPath = path.join(__dirname, '../frontend/dist');

// Serve the static files from the build folder
app.use(express.static(frontendDistPath));

// Catch-all route for Single Page Applications (React, Vue, Angular, etc.)
// Using the Regex /.*/ bypasses the Express string parser and safely catches all non-API frontend routes.
app.get(/.*/, (req, res) => {
  res.sendFile(path.join(frontendDistPath, 'index.html'));
}); 

// --- ERROR HANDLING MIDDLEWARE ---
app.use((err, req, res, next) => {
    console.error(err.stack);
    res.status(500).json({ error: 'Something went wrong on the server!' });
});

// --- START SERVER ---
const PORT = process.env.PORT || 8000;
app.listen(PORT, () => {
    console.log(`🚀 Server running on port ${PORT}`);
});
